<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AutoIA - Tu Negocio Nunca Duerme</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-primary: #000000;
            --bg-secondary: #111111;
            --text-primary: #ffffff;
            --text-secondary: #86868b;
            --accent: #2997ff;
            --gray: #1d1d1f;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-primary);
            color: var(--text-primary);
            overflow-x: hidden;
            line-height: 1.47059;
            font-weight: 400;
            letter-spacing: -0.022em;
        }

        nav {
            position: fixed;
            top: 0;
            width: 100%;
            height: 48px;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(20px);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .nav-content {
            width: 100%;
            max-width: 1024px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 20px;
        }

        .logo {
            font-size: 21px;
            font-weight: 600;
            letter-spacing: -0.5px;
        }

        .logo span {
            font-weight: 300;
            color: var(--text-secondary);
        }

        .nav-links {
            display: flex;
            gap: 40px;
            list-style: none;
            font-size: 12px;
            color: var(--text-secondary);
        }

        .nav-links a {
            color: var(--text-secondary);
            text-decoration: none;
            transition: color 0.3s;
        }

        .nav-links a:hover {
            color: var(--text-primary);
        }

        .hero {
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            position: relative;
            overflow: hidden;
            background: var(--bg-primary);
        }

        .hero-content {
            z-index: 2;
            opacity: 0;
            transform: translateY(30px);
            animation: fadeInUp 1.5s ease-out forwards;
        }

        .hero h1 {
            font-size: 96px;
            font-weight: 700;
            letter-spacing: -0.015em;
            line-height: 1.05;
            margin-bottom: 20px;
            background: linear-gradient(180deg, #fff 0%, #999 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero .subtitle {
            font-size: 28px;
            font-weight: 400;
            color: var(--text-secondary);
            margin-bottom: 40px;
            opacity: 0;
            animation: fadeInUp 1.5s ease-out 0.3s forwards;
        }

        .hero .cta-button {
            display: inline-block;
            background: var(--accent);
            color: white;
            padding: 18px 40px;
            border-radius: 50px;
            text-decoration: none;
            font-size: 17px;
            font-weight: 500;
            opacity: 0;
            animation: fadeInUp 1.5s ease-out 0.6s forwards;
            transition: transform 0.3s, box-shadow 0.3s;
        }

        .hero .cta-button:hover {
            transform: scale(1.05);
            box-shadow: 0 10px 40px rgba(41, 151, 255, 0.3);
        }

        .hero .secondary-link {
            display: block;
            margin-top: 20px;
            color: var(--accent);
            text-decoration: none;
            font-size: 19px;
            opacity: 0;
            animation: fadeInUp 1.5s ease-out 0.9s forwards;
        }

        .hero .secondary-link:hover {
            text-decoration: underline;
        }

        .scroll-indicator {
            position: absolute;
            bottom: 40px;
            left: 50%;
            transform: translateX(-50%);
            animation: bounce 2s infinite;
            opacity: 0.5;
        }

        @keyframes bounce {
            0%, 20%, 50%, 80%, 100% { transform: translateX(-50%) translateY(0); }
            40% { transform: translateX(-50%) translateY(-10px); }
            60% { transform: translateX(-50%) translateY(-5px); }
        }

        .section {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 100px 20px;
            position: relative;
            background: var(--bg-primary);
        }

        .section.sticky {
            position: sticky;
            top: 0;
        }

        .section-content {
            max-width: 980px;
            width: 100%;
            text-align: center;
        }

        .section h2 {
            font-size: 80px;
            font-weight: 700;
            letter-spacing: -0.015em;
            margin-bottom: 30px;
            line-height: 1.1;
        }

        .section h3 {
            font-size: 40px;
            font-weight: 600;
            letter-spacing: -0.015em;
            margin-bottom: 20px;
            color: var(--text-primary);
        }

        .section p {
            font-size: 21px;
            color: var(--text-secondary);
            max-width: 600px;
            margin: 0 auto 40px;
            line-height: 1.5;
        }

        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            max-width: 1200px;
            width: 100%;
            margin-top: 60px;
        }

        .service-card {
            background: var(--gray);
            border-radius: 24px;
            padding: 50px 40px;
            text-align: left;
            transition: transform 0.5s, box-shadow 0.5s;
            opacity: 0;
            transform: translateY(50px);
        }

        .service-card.visible {
            opacity: 1;
            transform: translateY(0);
        }

        .service-card:hover {
            transform: scale(1.02);
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
        }

        .service-icon {
            font-size: 48px;
            margin-bottom: 20px;
        }

        .service-card h4 {
            font-size: 24px;
            font-weight: 600;
            margin-bottom: 15px;
        }

        .service-card p {
            font-size: 17px;
            color: var(--text-secondary);
            margin-bottom: 25px;
            text-align: left;
        }

        .price {
            font-size: 28px;
            font-weight: 600;
            color: var(--text-primary);
        }

        .price span {
            font-size: 15px;
            color: var(--text-secondary);
            font-weight: 400;
        }

        .features-list {
            list-style: none;
            max-width: 800px;
            margin: 60px auto;
        }

        .features-list li {
            font-size: 24px;
            padding: 30px 0;
            border-bottom: 1px solid var(--gray);
            display: flex;
            align-items: center;
            gap: 20px;
            opacity: 0;
            transform: translateX(-30px);
            transition: all 0.6s;
        }

        .features-list li.visible {
            opacity: 1;
            transform: translateX(0);
        }

        .features-list li::before {
            content: '?';
            color: var(--accent);
            font-weight: 700;
            font-size: 28px;
        }

        #faq {
            padding-bottom: 150px !important;
            margin-bottom: 0;
            background: var(--bg-primary);
        }

        .faq-container {
            max-width: 800px;
            width: 100%;
            margin-top: 60px;
        }

        .faq-item {
            border-bottom: 1px solid var(--gray);
            overflow: hidden;
        }

        .faq-question {
            width: 100%;
            padding: 30px 0;
            background: none;
            border: none;
            color: var(--text-primary);
            font-size: 21px;
            font-weight: 600;
            text-align: left;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: color 0.3s;
        }

        .faq-question:hover {
            color: var(--accent);
        }

        .faq-icon {
            font-size: 24px;
            transition: transform 0.3s;
            color: var(--text-secondary);
        }

        .faq-item.active .faq-icon {
            transform: rotate(45deg);
        }

        .faq-answer {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.5s ease-out;
        }

        .faq-answer p {
            padding-bottom: 30px;
            font-size: 17px;
            color: var(--text-secondary);
            text-align: left;
        }

        .cta-section {
            position: relative;
            z-index: 10;
            background: var(--bg-secondary) !important;
            margin-top: 0;
            border-top: 2px solid #333;
            text-align: center;
            padding: 150px 20px;
        }

        .cta-section h2 {
            font-size: 64px;
            margin-bottom: 30px;
        }

        .cta-section p {
            font-size: 24px;
            color: var(--text-secondary);
            margin-bottom: 50px;
        }

        .cta-buttons {
            display: flex;
            gap: 20px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-primary {
            background: var(--accent);
            color: white;
            padding: 18px 40px;
            border-radius: 50px;
            text-decoration: none;
            font-size: 17px;
            font-weight: 500;
            transition: transform 0.3s;
        }

        .btn-primary:hover {
            transform: scale(1.05);
        }

        .btn-secondary {
            background: transparent;
            color: var(--accent);
            border: 2px solid var(--accent);
            padding: 16px 38px;
            border-radius: 50px;
            text-decoration: none;
            font-size: 17px;
            font-weight: 500;
            transition: all 0.3s;
        }

        .btn-secondary:hover {
            background: var(--accent);
            color: white;
        }

        #demo {
            background: var(--bg-secondary);
            padding: 100px 20px;
        }

        .business-selector {
            display: flex;
            gap: 20px;
            justify-content: center;
            margin-bottom: 40px;
            flex-wrap: wrap;
        }

        .business-btn {
            background: transparent;
            border: 2px solid #444;
            color: #888;
            padding: 15px 40px;
            border-radius: 50px;
            cursor: pointer;
            font-size: 18px;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .business-btn:hover {
            border-color: #666;
            color: #aaa;
        }

        .business-btn.active {
            background: var(--accent);
            border-color: var(--accent);
            color: white;
        }

        .phone-mockup {
            width: 300px;
            height: 600px;
            background: #1a1a1a;
            border-radius: 40px;
            padding: 20px;
            margin: 0 auto;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            border: 8px solid #333;
            position: relative;
            overflow: hidden;
        }

        .phone-screen {
            width: 100%;
            height: 100%;
            background: #075e54;
            border-radius: 30px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .whatsapp-header {
            background: #128c7e;
            padding: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .whatsapp-header .avatar {
            width: 40px;
            height: 40px;
            background: #ddd;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .whatsapp-header .info h4 {
            color: white;
            font-size: 16px;
            margin: 0;
        }

        .whatsapp-header .info p {
            color: rgba(255,255,255,0.8);
            font-size: 12px;
            margin: 0;
        }

        .chat-container {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .message {
            max-width: 80%;
            padding: 12px 16px;
            border-radius: 20px;
            font-size: 14px;
            line-height: 1.4;
            opacity: 0;
            transform: translateY(20px);
            transition: all 0.5s ease-out;
        }

        .message.show {
            opacity: 1;
            transform: translateY(0);
        }

        .message.received {
            background: white;
            color: black;
            align-self: flex-start;
            border-bottom-left-radius: 5px;
        }

        .message.sent {
            background: #dcf8c6;
            color: black;
            align-self: flex-end;
            border-bottom-right-radius: 5px;
        }

        .timestamp {
            font-size: 11px;
            color: rgba(255,255,255,0.6);
            text-align: center;
            margin: 10px 0;
        }

        .input-area {
            background: #f0f0f0;
            padding: 10px;
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .input-area input {
            flex: 1;
            border: none;
            background: white;
            padding: 12px 20px;
            border-radius: 25px;
            outline: none;
        }

        .input-area button {
            background: #128c7e;
            color: white;
            border: none;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            cursor: pointer;
        }

        .demo-controls {
            margin-top: 40px;
            display: flex;
            gap: 15px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .demo-btn {
            background: transparent;
            border: 2px solid var(--accent);
            color: var(--accent);
            padding: 12px 25px;
            border-radius: 50px;
            cursor: pointer;
            font-size: 15px;
            transition: all 0.3s;
        }

        .demo-btn:hover {
            background: var(--accent);
            color: white;
        }

        .feature-highlight {
            background: var(--gray);
            padding: 30px;
            border-radius: 20px;
            margin-top: 40px;
            max-width: 800px;
        }

        .feature-highlight h4 {
            font-size: 24px;
            margin-bottom: 15px;
            color: var(--text-primary);
        }

        .feature-highlight p {
            color: var(--text-secondary);
            font-size: 17px;
        }

        .data-visualization {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-top: 30px;
        }

        .data-card {
            background: rgba(255,255,255,0.05);
            padding: 20px;
            border-radius: 15px;
            text-align: center;
        }

        .data-card .number {
            font-size: 28px;
            font-weight: 700;
            color: var(--accent);
            min-height: 36px;
        }

        .data-card .label {
            font-size: 13px;
            color: var(--text-secondary);
            margin-top: 5px;
        }

        .footer-main {
            background: #0a0a0a;
            padding: 60px 20px 30px;
            border-top: 1px solid #222;
        }

        .footer-content {
            max-width: 980px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 40px;
            margin-bottom: 40px;
        }

        .footer-column h5 {
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-secondary);
            margin-bottom: 20px;
            font-weight: 600;
        }

        .footer-column ul {
            list-style: none;
        }

        .footer-column li {
            margin-bottom: 12px;
        }

        .footer-column a {
            color: #666;
            text-decoration: none;
            font-size: 13px;
            transition: color 0.3s;
        }

        .footer-column a:hover {
            color: var(--text-primary);
        }

        .footer-bottom {
            border-top: 1px solid #222;
            padding-top: 30px;
            text-align: center;
        }

        .footer-bottom p {
            font-size: 12px;
            color: #444;
            margin-bottom: 10px;
        }

        .footer-bottom .legal-links {
            display: flex;
            gap: 30px;
            justify-content: center;
            flex-wrap: wrap;
            margin-top: 15px;
        }

        .footer-bottom .legal-links a {
            color: #666;
            text-decoration: none;
            font-size: 12px;
        }

        .footer-bottom .legal-links a:hover {
            color: var(--text-primary);
        }

        @keyframes fadeInUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @media (max-width: 768px) {
            .hero h1 { font-size: 48px; }
            .hero .subtitle { font-size: 21px; }
            .section h2 { font-size: 48px; }
            .section h3 { font-size: 32px; }
            .services-grid { grid-template-columns: 1fr; }
            .nav-links { display: none; }
            .cta-section h2 { font-size: 40px; }
            .phone-mockup { width: 280px; height: 560px; }
            .footer-content { grid-template-columns: 1fr; text-align: center; }
            .data-visualization { grid-template-columns: 1fr; }
        }

        .reveal {
            opacity: 0;
            transform: translateY(50px);
            transition: all 1s ease-out;
        }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }
    </style>
</head>
<body>

    <nav>
        <div class="nav-content">
            <div class="logo">Auto<span>IA</span></div>
            <ul class="nav-links">
                <li><a href="#servicios">Servicios</a></li>
                <li><a href="#como-funciona">C mo Funciona</a></li>
                <li><a href="#demo">Demo</a></li>
                <li><a href="#faq">FAQ</a></li>
                <li><a href="#contacto">Contacto</a></li>
            </ul>
        </div>
    </nav>

    <section class="hero">
        <div class="hero-content">
            <h1>Tu Recepcionista<br>Inteligente</h1>
