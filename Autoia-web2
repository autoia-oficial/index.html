        function setBusiness(type) {
            currentBusiness = type;
            
            document.querySelectorAll('.business-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            event.target.classList.add('active');
            
            document.getElementById('business-avatar').textContent = businessConfig[type].avatar;
            document.getElementById('business-name').textContent = businessConfig[type].name;
            
            resetDemo();
            
            setTimeout(() => {
                const chat = document.getElementById('chat');
                const welcomeDiv = document.createElement('div');
                welcomeDiv.className = 'message received show';
                welcomeDiv.textContent = businessConfig[type].welcome;
                chat.appendChild(welcomeDiv);
            }, 300);
        }

        function runScenario(type) {
            messageTimeouts.forEach(timeout => clearTimeout(timeout));
            messageTimeouts = [];
            
            const chat = document.getElementById('chat');
            const scenario = scenarios[currentBusiness][type];
            
            if (!scenario) return;

            scenario.forEach((msg) => {
                const timeout = setTimeout(() => {
                    const messageDiv = document.createElement('div');
                    messageDiv.className = `message ${msg.type}`;
                    messageDiv.textContent = msg.text;
                    chat.appendChild(messageDiv);
                    
                    requestAnimationFrame(() => {
                        messageDiv.classList.add('show');
                    });
                    
                    chat.scrollTop = chat.scrollHeight;

                    if (msg.final && msg.data) {
                        updateDataViz(msg.data);
                    }
                }, msg.delay);
                
                messageTimeouts.push(timeout);
            });
        }

        function resetDemo() {
            messageTimeouts.forEach(timeout => clearTimeout(timeout));
            messageTimeouts = [];
            
            const chat = document.getElementById('chat');
            chat.innerHTML = '<div class="timestamp">Hoy</div>';
            
            document.getElementById('data-name').textContent = '-';
            document.getElementById('data-service').textContent = '-';
            document.getElementById('data-time').textContent = '-';
            
            setTimeout(() => {
                const welcomeDiv = document.createElement('div');
                welcomeDiv.className = 'message received show';
                welcomeDiv.textContent = businessConfig[currentBusiness].welcome;
                chat.appendChild(welcomeDiv);
            }, 200);
        }

        function updateDataViz(data) {
            document.getElementById('data-name').textContent = data.name;
            document.getElementById('data-service').textContent = data.service;
            document.getElementById('data-time').textContent = data.time;
            
            document.querySelectorAll('.data-card').forEach(card => {
                card.style.transform = 'scale(1.05)';
                setTimeout(() => {
                    card.style.transform = 'scale(1)';
                }, 200);
            });
        }

        window.addEventListener('load', () => {
            setTimeout(() => {
                const chat = document.getElementById('chat');
                if (chat && chat.children.length === 1) {
                    const welcomeDiv = document.createElement('div');
                    welcomeDiv.className = 'message received show';
                    welcomeDiv.textContent = businessConfig.barberia.welcome;
                    chat.appendChild(welcomeDiv);
                }
            }, 500);
        });
    </script>

