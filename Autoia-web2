    <section id="faq" class="section">
        <div class="section-content">
            <h2 class="reveal">Preguntas frecuentes.</h2>
            
            <div class="faq-container reveal">
                <div class="faq-item">
                    <button class="faq-question">
                         Necesito saber de tecnolog a?
                        <span class="faq-icon">+</span>
